#!/bin/bash -l
#$ -N pir_train_real
#$ -cwd
#$ -j y
#$ -o logs/qsub/$JOB_NAME.$JOB_ID.log
#$ -l h_rt=01:30:00
#$ -pe omp 4

set -euo pipefail

PROJECT_DIR="/projectnb/se740/scifry-SCSP/ProtocolIR"
cd "$PROJECT_DIR"
mkdir -p logs/qsub .uv-cache models

module load python3/3.12.4 uv/0.7.3

export UV_CACHE_DIR="$PROJECT_DIR/.uv-cache"
if [ ! -d .venv ]; then
  uv venv .venv --python 3.12
fi
source .venv/bin/activate

uv pip install -r requirements.txt
uv pip install -e .

# This training script uses local expert/corrupted data and does not need LLM inference.
python train_on_real_data.py

echo "Training complete: models/learned_weights.json"
