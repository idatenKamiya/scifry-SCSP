        "guid": "A4D74960D21211F09A000A58A9FEAC02",
        "previous_id": 8575450,
        "previous_guid": "A4D73F34D21211F09A000A58A9FEAC02",
        "section": "<p>Set up and run the real-time PCR instrument</p>",
        "section_color": "#aa90fe",
        "section_duration": 0,
        "is_substep": true,
        "step": "Set the reaction volume appropriate for the type of plate being used for your PCR reaction.\nPay attention to whether you are using a 0.1 or 0.2 ml 96 well plate, the experiment files are not compatible between the two plate sizes.",
        "data": null,
        "protocol_id": 234300,
        "case_id": 0,
