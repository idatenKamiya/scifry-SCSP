      {
        "id": 8575449,
        "guid": "A4D73A99D21211F09A000A58A9FEAC02",
        "previous_id": 8575458,
        "previous_guid": "650382A0B01648EEB8658FC65839EB38",
        "section": "<p>Set up and run the real-time PCR instrument</p>",
        "section_color": "#aa90fe",
        "section_duration": 0,
        "is_substep": false,
        "step": "Set the instrument to perform a default dissociation step.\nA dissociation step can be performed up to 72 hours after the real-time PCR run if the plate is stored in the dark and up to 24 hours after the real-time PCR run if the plate is exposed to light.",
        "data": null,
        "protocol_id": 234300,
        "case_id": 0,
        "critical_ids": "",
        "duration": 0,
        "original_id": 0,
        "number": "12",
        "cases": [],
        "critical": null
      },
      {
        "id": 8575450,
        "guid": "A4D73F34D21211F09A000A58A9FEAC02",
        "previous_id": 8575459,
        "previous_guid": "288AFB811FAD4B97B9C7E45A60B3F509",
        "section": "<p>Set up and run the real-time PCR instrument</p>",
        "section_color": "#aa90fe",
        "section_duration": 0,
        "is_substep": false,
        "step": "Use the following settings for Applied Biosystems\u2122 instruments:\nExperiment type: Standard curve or Relative Quantification\nReagent: SYBR\u2122 Green reagents\nReporter: SYBR\u2122\nQuencher: None\nPassive reference dye: ROX\u2122\nRamp speed: Standard or fast (choose the same setting as in step 2)\nMelt curve ramp increment: Continuous",
        "data": null,
        "protocol_id": 234300,
        "case_id": 0,
        "critical_ids": "",
        "duration": 0,
        "original_id": 0,
        "number": "14",
        "cases": [],
        "critical": null
      },
      {
