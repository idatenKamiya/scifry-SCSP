# OpenRouter API Configuration
# Do not commit a real key. Set this in your shell or a local, ignored .env file.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model configuration
# Use a specific free model that supports response_format/structured_outputs.
# Avoid openrouter/free for the final demo because generic routing can fail when
# strict JSON-schema parameters are required.
PROTOCOLIR_MODEL=inclusionai/ling-2.6-flash:free
PROTOCOLIR_MAX_TOKENS=4096

# protocols.io API Configuration (optional data fetch scripts)
PROTOCOLS_IO_CLIENT_ID=your_client_id_here
PROTOCOLS_IO_CLIENT_SECRET=your_client_secret_here
PROTOCOLS_IO_ACCESS_TOKEN=your_access_token_here

# Optional: Opentrons configuration
OPENTRONS_SIMULATE=true
OPENTRONS_PYTHON_PATH=/path/to/python

# Optional: Output directory
PROTOCOLIR_OUTPUT_DIR=./outputs
