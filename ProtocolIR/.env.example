# Anthropic API Configuration
ANTHROPIC_API_KEY=your_api_key_here

# Optional: Model configuration
PROTOCOLIR_MODEL=claude-opus-4-7
PROTOCOLIR_MAX_TOKENS=2048

# Optional: Opentrons configuration
OPENTRONS_SIMULATE=true
OPENTRONS_PYTHON_PATH=/path/to/python  # Optional: path to Python with opentrons installed

# Optional: Output directory
PROTOCOLIR_OUTPUT_DIR=./outputs
