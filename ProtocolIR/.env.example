# LLM provider configuration
# Supported values: ollama, anthropic
PROTOCOLIR_LLM_PROVIDER=ollama
PROTOCOLIR_MODEL=llama3.1:8b
PROTOCOLIR_MAX_TOKENS=2048
PROTOCOLIR_TEMPERATURE=0
PROTOCOLIR_LLM_TIMEOUT=120

# Ollama configuration (default provider)
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Optional for proxied Ollama deployments requiring auth
OLLAMA_API_KEY=

# Anthropic configuration (only needed if PROTOCOLIR_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# protocols.io API Configuration (for data fetch scripts)
PROTOCOLS_IO_CLIENT_ID=your_client_id_here
PROTOCOLS_IO_CLIENT_SECRET=your_client_secret_here
PROTOCOLS_IO_ACCESS_TOKEN=your_access_token_here

# Optional: Opentrons configuration
OPENTRONS_SIMULATE=true
OPENTRONS_PYTHON_PATH=/path/to/python  # Optional: path to Python with opentrons installed

# Optional: Output directory
PROTOCOLIR_OUTPUT_DIR=./outputs
